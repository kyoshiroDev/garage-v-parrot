{% extends 'base.html.twig' %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('assets/css/Login/style.css') }}">
{% endblock %}

{% block javascripts %}
	{{ parent() }}
{% endblock %}

{% block body %}
	<div class="container">
		<form class:"form" action="{{ path('app_login') }}" method="post">
			<img class="logo" src="{{ asset('assets/images/Header/Logo2.png') }}" alt="Logo de la société">
			<h3 class="text-center">Connexion</h3>
			<div class="mb-3">
				<label for="username" class="form-label">Email</label>
				<input type="email" class="form-control" id="username" placeholder="exemple@gmail.com" name="_username">
			</div>
			<div class="mb-3">
				<label for="password" class="form-label">Mot de passe</label>
				<input type="password" class="form-control" id="password" name="_password" placeholder="**********">
			</div>
			<button type="submit" class="btn ">Se connecter</button>
		</form>
	</div>
{% endblock %}
