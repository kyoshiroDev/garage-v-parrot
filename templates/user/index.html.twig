{% extends "base.html.twig" %}
{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('assets/css/User/style.css') }}">
	<link rel="stylesheet" href="{{ asset('assets/css/NavBarAdmin/style.css') }}">
{% endblock %}

{% block javascripts %}
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous" defer></script>

	<script src="{{ asset('assets/js/NavAdmin/script.js') }}" defer></script>
	<script src="{{ asset('assets/js/User/script.js') }}" defer></script>
{% endblock %}

{% block body %}
	{% include "admin/dashboard.html.twig" %}

	<main class="w-auto">
		<div class="search-input container w-50">
			<input type="text" id="myInput" placeholder="Rechercher" title="Type in a name" class="container d-flex flex-raw justify-content-start align-items-center sm-px-2 mt-5 search">
		</div>
		<div class="container d-flex flex-column justify-content-center align-items-center sm-px-2 mt-5 main-index">
			<div class="d-flex justify-content-end align-items-center pe-3 w-100 mt-4">
				<button type="button" onclick="window.location.href = '{{ path('app_user_new') }}'" class="btn btn-danger text-center" style="width: 150px">
					Nouveau
				</button>
			</div>
			<table class="container table">
				<thead>
					<tr class="text-center fs-4 w-25">
						<th>Nom</th>
						<th>Prenom</th>
						<th class="d-none d-lg-table-cell">Email</th>
						<th class="d-none d-xl-table-cell">Roles</th>
						<th class="d-none d-xl-table-cell">Date de création</th>
						<th></th>
					</tr>
				</thead>
				<tbody class="table-results"></tbody>
			</table>
		</div>
	</div>
</main>{% endblock %}
