{% extends 'base.html.twig' %}

{% block title %}User index
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
  <link rel="stylesheet" href="{{ asset('assets/css/index-user/style.css') }}">
{% endblock %}

{% block javascripts %}
	{{ parent() }}
{% endblock %}

{% block body %}
	<main class="w-100">
		<h1 class="text-center fs-1 m-5 w-100">Liste des employés</h1>
		<div class="container d-flex justify-content-end align-items-center pe-3 w-100">
			<button type="button" onclick="window.location.href = '{{ path('app_user_new') }}'" class="btn btn-primary text-center" style="width: 150px">
				Nouveau
			</button>
		</div>
		<table class="container table p-3 my-0">
			<thead class="">
				<tr class="text-center fs-4">
					<th class="">Id</th>
					<th>Nom</th>
					<th>Prenom</th>
					<th class="">Email</th>
					<th class="">Date de création</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				{% for user in users %}
					<tr class="text-center fs-6">
						<td class="align-middle">{{ user.id }}</td>
						<td class="align-middle">{{ user.lastName }}</td>
						<td class="align-middle">{{ user.firstName }}</td>
						<td class="align-middle">{{ user.email }}</td>
						<td class="align-middle">{{ user.createdAt ? user.createdAt|date('d-m-Y') : '' }}</td>
						<td>
							<div class="btn-group" role="group" aria-label="Basic outlined example">
								<button type="button" class="btn btn-outline-primary" onclick="window.location.href = '{{ path('app_user_show', {'id': user.id}) }}'">
									Voir
								</button>
								<button type="button" class="btn btn-outline-primary" onclick="window.location.href = '{{ path('app_user_edit', {'id': user.id}) }}'">
									Modifier
								</button>
							</div>
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="5">no records found</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
		<main>
		{% endblock %}
