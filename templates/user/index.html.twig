{% extends 'base.html.twig' %}

{% block title %}User index
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
{% endblock %}

{% block javascripts %}
	{{ parent() }}
{% endblock %}

{% block body %}
	<main class="d-flex flex-column align-items-center justify-content-center">
		<h1 class="text-center fs-1 m-5">Liste des employés</h1>
		<div class="d-flex justify-content-end align-items-center me-3 w-75">
			<button type="button" onclick="window.location.href = '{{ path('app_user_new') }}'" class="btn btn-primary text-center" style="width: 150px">
				Nouveau
			</button>
		</div>
		<table class="table p-3 w-75 m-0">
			<thead class="">
				<tr class="text-center fs-4">
					<th>Id</th>
					<th>Nom</th>
					<th>Prenom</th>
					<th>Email</th>
					<th>Date de création</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				{% for user in users %}
					<tr class="text-center fs-6">
						<td>{{ user.id }}</td>
						<td>{{ user.lastName }}</td>
						<td>{{ user.firstName }}</td>
						<td>{{ user.email }}</td>
						<td>{{ user.createdAt ? user.createdAt|date('d-m-Y') : '' }}</td>
						<td>
							<div class="btn-group" role="group" aria-label="Basic outlined example">
								<button type="button" class="btn btn-outline-primary" onclick="window.location.href = '{{ path('app_user_show', {'id': user.id}) }}'">
									Voir
								</button>
								<button type="button" class="btn btn-outline-primary" onclick="window.location.href = '{{ path('app_user_edit', {'id': user.id}) }}'">
									Modifier
								</button>
								<button type="button" class="btn btn-outline-primary" onclick="window.location.href = '{{ path('app_user_delete', {'id': user.id}) }}'">
									Supprimer
								</button>
							</div>
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="5">no records found</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
		<main>
		{% endblock %}
