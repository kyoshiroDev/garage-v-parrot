{% extends 'base.html.twig' %}

{% block title %}Nouvelle utlisateur
{% endblock %}

{% block stylesheets %}
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
	<link rel="stylesheet" href="{{ asset('assets/css/form/style.css') }}">
{% endblock %}

{% block javascripts %}
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous" defer></script>
{% endblock %}

{% block body %}
	<main>
		<form class="d-flex flex-column justify-content-center align-items-center mh-100 m-4" method="POST">
			<img class="logo" src="{{ asset('assets/images/Header/Logo2.png') }}" alt="Logo de la société">
			<div class="d-flex flex-column aligne-items-center justify-content-center p-3 fs-6">
				<h1 class="text-center my-5">Ajout d'un utilisateur</h1>
				{{ form_start(form) }}
				{{ form_row(form.lastName)}}
				{{ form_row(form.firstName) }}
				{{ form_row(form.email) }}
				{{ form_row(form.password) }}
				<div class="button-container">
					<input type="submit" value="Envoyer" class="btn btn-success m-1 button"></input>
					<button type="button" class="btn btn-danger m-1 button" onclick="window.location.href='{{ path('app_user_index') }}'">Annuler</button>
				</div>
				{{ form_end(form) }}
			</div>
		</form>
	</main>
{% endblock %}
