{% extends 'base.html.twig' %}

{% block title %}User
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('assets/css/User-show/style.css') }}">
	<link rel="stylesheet" href="{{ asset('assets/css/NavBarAdmin/style.css') }}">
{% endblock %}


	{% block javascripts %}
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous" defer></script>
	{% endblock %}

{% block body %}
	{% include "admin/dashboard.html.twig" %}
	<div class=" main p-4">
		<div class="container mt-5 main-index d-flex flex-column justify-content-center align-items-center" style="background-color: #ffff">
			<h2 class="pt-2 fs-1">{{ user.lastName }}
				{{ user.firstName }}</h2>
			<div class="container card-body fs-6 p-2">
				<table class="container table">
					<tbody>
						<tr>
							<th>Id</th>
							<td>{{ user.id }}</td>
						</tr>
						<tr>
							<th>Email</th>
							<td>{{ user.email }}</td>
						</tr>
						<tr>
							<th>Roles</th>
							<td>{{ user.roles ? user.roles|json_encode : '' }}</td>
						</tr>
						{# <tr>
													<th>Password</th>
													<td>{{ user.password }}</td>
												</tr> #}
						<tr>
							<th>Date de création</th>
							<td>{{ user.createdAt ? user.createdAt|date('d-m-Y') : '' }}</td>
						</tr>
					</tbody>
				</table>
				<div class="d-flex justify-content-between align-items-center fs-6 p-2">
					<a class="text-danger" href="{{ path('app_user_index') }}">Revenir a la liste</a>
					{{ include('user/_delete_form.html.twig') }}
				</div>
			</div>
		</div>
	</div>
{% endblock %}
