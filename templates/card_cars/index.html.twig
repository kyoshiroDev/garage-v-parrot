{% extends "base.html.twig" %}
{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('assets/css/User/style.css') }}">
	<link rel="stylesheet" href="{{ asset('assets/css/NavBarAdmin/style.css') }}">
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="{{ asset('assets/js/NavAdmin/script.js') }}" defer></script>
{% endblock %}

{% block body %}
	{% include "Users/dashboard.html.twig" %}
	<h1 class="text-center m-3">Tableaux des annonces</h1>
	<div class="container">
		<table class="table fs-6 border mt-3">
			<thead class="text-center">
				<tr>
					<th>Id</th>
					<th>Marque</th>
					<th>Model</th>
					<th>Kilometre</th>
					<th>Porte</th>
					<th>Puissance</th>
					<th>Annee</th>
					<th>Prix</th>
					<th>Energie</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				{% for card_car in card_cars %}
					<tr class="text-center">
						<td style="vertical-align: middle;">{{ card_car.id }}</td>
						<td style="vertical-align: middle;">{{ card_car.marque }}</td>
						<td style="vertical-align: middle;">{{ card_car.model }}</td>
						<td style="vertical-align: middle;">{{ card_car.kilometre }}</td>
						<td style="vertical-align: middle;">{{ card_car.porte }}</td>
						<td style="vertical-align: middle;">{{ card_car.puissance }}</td>
						<td style="vertical-align: middle;">{{ card_car.annee }}</td>
						<td style="vertical-align: middle;">{{ card_car.prix }}</td>
						<td style="vertical-align: middle;">{{ card_car.energie }}</td>
						<td>
							<div class="btn-group " role="group" aria-label="Basic outlined example">
								<button type="button" class="btn btn-outline-primary">
									<a href="{{ path('app_card_cars_show', {'id': card_car.id}) }}">Voir</a>
								</button>
								<button type="button" class="btn btn-outline-primary">
									<a href="{{ path('app_card_cars_edit', {'id': card_car.id}) }}"></a>Modifier</button>
								<button type="button" class="btn btn-outline-primary">
									<a href="{{ path('app_card_cars_delete', {'id': card_car.id}) }}"></a>Supprimer</button>
							</div>
						</td>
						<div class="d-flex justify-content-end me-5">
							<button type="button" class="btn btn-primary align-">
								<a href="{{ path('app_card_cars_new') }}"></a>Ajouter
							</button>
						</div>
					</tr>
				{% else %}
					<tr>
						<td colspan="10">no records found</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>

{% endblock %}
