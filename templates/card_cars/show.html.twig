{% extends 'base.html.twig' %}

{% block title %}Occasions
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
{% endblock %}

{% block javascripts %}
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous" defer></script>
{% endblock %}

{% block body %}

	{% include "_part/nav.html.twig" %}
<main class="d-flex flex-column align-item-center h-100 justify-content-center w-100">

	<div class="d-flex flex-wrap align-item-center justify-content-center">

		<div class="card m-3" style="width: 23rem;">

			{% if card_car.imageName %}
				<img src="{{ vich_uploader_asset(card_car) }}" alt="{{ card_car.marque }}">
			{% endif %}

			<div class="card-body m-auto">
				<h5 class="card-title fs-1">{{ card_car.marque }}
					{{ card_car.model }}</h5>
			</div>
			<ul class="list-group list-group-flush">
				<li class="list-group-item d-flex justify-content-between fs-6">
					<div>Kilomètrage:</div>
					<div>{{ card_car.kilometre }}</div>
				</li>
				<li class="list-group-item d-flex justify-content-between fs-6">
					<div>Portes:</div>
					<div>{{ card_car.porte }}</div>
				</li>
				<li class="list-group-item d-flex justify-content-between fs-6">
					<div>CV Fiscaux:</div>
					<div>{{ card_car.puissance }}</div>
				</li>
				<li class="list-group-item d-flex justify-content-between fs-6">
					<div>Premiére mise en cirdulation:</div>
					<div>{{ card_car.annee }}</div>
				</li>
				<li class="list-group-item d-flex justify-content-between fs-6">
					<div>Energie:</div>
					<div>{{ card_car.energie }}</div>
				</li>
				<li class="list-group-item d-flex justify-content-between fs-6">
					<div>Prix:</div>
					<div>{{ card_car.prix }}
						&euro;</div>
				</li>
			</ul>
			<div class="card-body m-auto">
				<div class="d-flex text-align-center justify-content-center mb-3">
					<h5 class="m-auto fs-4">Contact</h5>
				</div>
				<p class="fs-6 text-center">Par téléphone:
					<a href="tel:06.85.97.42.35" class="card-link">06.85.97.42.35</a><br>
					Ou via nôtre<a href="#" class="card-link">
						formulaire</a>
				</p>
				<div class="btn-group py-2" role="group" aria-label="Basic outlined example">
					<a href="{{ path('app_card_cars_index') }}" class="btn btn-outline-danger">Retour a la liste</a>
					<a href="{{ path('app_card_cars_edit', {'id': card_car.id}) }}" class="btn btn-outline-danger">Modifier</a>
					{{ include('card_cars/_delete_form.html.twig') }}
				</div>
			</div>
		</div>
	</div>
</main>
	{% include "_part/footer.html.twig" %}
{% endblock %}
